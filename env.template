# ============================================
# 🔐 VARIABLES DE ENTORNO - PLANTILLA
# ============================================
# Copia este archivo a .env.local y reemplaza los valores
# 
# Comando: cp env.template .env.local
# Luego edita .env.local con tus valores reales
# ============================================

# ============================================
# 🗄️ SUPABASE (Base de Datos) - OBLIGATORIO
# ============================================
# Obtén estos valores desde:
# https://supabase.com/dashboard/project/[tu-proyecto]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# 🔐 AUTENTICACIÓN (Dashboard) - OBLIGATORIO
# ============================================
# Credenciales para acceder al dashboard en /dashboard
ADMIN_EMAIL=tu_email_admin_aqui
ADMIN_PASSWORD=tu_password_seguro_aqui

# Genera un JWT_SECRET seguro con:
# openssl rand -base64 32
# O cualquier generador de strings aleatorios (mínimo 32 caracteres)
JWT_SECRET=tu-secret-key-muy-largo-y-aleatorio-minimo-32-caracteres-aqui

# ============================================
# 📧 RESEND (Emails) - OBLIGATORIO
# ============================================
# Obtén tu API key desde: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# En modo sandbox (pruebas), usa:
EMAIL_FROM=onboarding@resend.dev

# En producción, usa tu dominio verificado:
# EMAIL_FROM=noreply@psicoterapiamaria.online

# Email que recibirá las notificaciones de nuevas citas
RECIPIENT_EMAIL=tu_email_para_recibir_notificaciones_aqui

# ============================================
# 🌐 BASE URL - OBLIGATORIO
# ============================================
# En desarrollo local: http://localhost:3000
# En producción: https://psicoterapiamaria.online
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# 📅 GOOGLE CALENDAR (OAuth 2.0) - OPCIONAL
# ============================================
# Solo si quieres usar Google Calendar para crear eventos automáticamente
# 
# Obtén estos valores desde:
# https://console.cloud.google.com/apis/credentials
#
# IMPORTANTE: En Google Cloud Console, agrega esta URI de redirección:
# Para desarrollo: http://localhost:3000/api/google-calendar/callback
# Para producción: https://psicoterapiamaria.online/api/google-calendar/callback
GOOGLE_CLIENT_ID=tu_client_id_de_google_cloud_console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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loud_console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-calendar/callback

# ============================================
# 💳 FLOW (Pagos) - OPCIONAL
# ============================================
# Solo si quieres integrar pagos con Flow
# 
# Sandbox (pruebas): https://sandbox.flow.cl/
# Producción: https://flow.cl/
FLOW_API_KEY=tu_flow_api_key_aqui
FLOW_SECRET_KEY=tu_flow_secret_key_aqui
FLOW_ENVIRONMENT=sandbox

# ============================================
# 💳 TRANSBANK WEBPAY PLUS - OPCIONAL
# ============================================
# Solo si quieres integrar pagos con Transbank
# 
# Credenciales de prueba (integration):
# TRANSBANK_COMMERCE_CODE=597055555532
# TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TRANSBANK_COMMERCE_CODE=tu_commerce_code_aqui
TRANSBANK_API_KEY=tu_api_key_aqui
TRANSBANK_ENVIRONMENT=integration

# ============================================
# 📧 CONTACTO - OPCIONAL
# ============================================
# Email de contacto que se muestra en el sitio web
NEXT_PUBLIC_CONTACT_EMAIL=tu_email_de_contacto_aqui

# ============================================
# 📝 NOTAS
# ============================================
# 
# 1. Copia este archivo: cp env.template .env.local
# 2. Edita .env.local con tus valores reales
# 3. Las variables con NEXT_PUBLIC_* son públicas (se exponen al cliente)
# 4. Las variables sin NEXT_PUBLIC_* son privadas (solo servidor)
# 5. NUNCA subas .env.local a git (ya está en .gitignore)
# 6. Para producción, configura las variables en Vercel Dashboard
#
# ============================================

